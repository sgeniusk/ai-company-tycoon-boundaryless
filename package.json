    "assets:v078": "node scripts/assets/generate-v078-world-reveal-stamp-atlas.mjs",
    "assets:v079": "node scripts/assets/generate-v079-product-domain-atlas.mjs",
    "assets:v080": "node scripts/assets/generate-v080-capability-research-atlas.mjs",
    "assets:v081": "node scripts/assets/generate-v081-office-reaction-atlas.mjs",
    "qa:office-visuals:screenshots": "node scripts/qa/capture-office-visuals-screenshots.mjs",
    "qa:blind-rehearsal": "node scripts/qa/run-v056-blind-rehearsal.mjs",
    "qa:blind-summary": "node scripts/qa/summarize-v056-blind-sessions.mjs",
    "qa:blind-readiness": "node scripts/qa/check-v056-blind-readiness.mjs",
    "qa:blind-preflight": "node scripts/qa/check-v056-blind-preflight.mjs",
    "qa:blind-url-sync": "node scripts/qa/sync-v056-blind-playtest-urls.mjs",
    "qa:blind-session-links": "node scripts/qa/prepare-v056-blind-session-links.mjs",
