    "assets:v053": "node scripts/assets/import-v053-character-source.mjs",
    "assets:v054": "node scripts/assets/generate-v046-hires-pixel-sheets.mjs && node scripts/assets/import-v054-office-art.mjs",
    "assets:v071": "node scripts/assets/generate-v071-commercial-ui-atlas.mjs",
    "assets:v072": "node scripts/assets/generate-v072-competitor-logo-atlas.mjs",
    "assets:v074": "node scripts/assets/generate-v074-helper-portrait-atlas.mjs",
    "assets:v075": "node scripts/assets/generate-v075-brand-crest-atlas.mjs",
