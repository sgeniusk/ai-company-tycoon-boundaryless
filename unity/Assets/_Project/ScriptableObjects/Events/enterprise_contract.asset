  m_Script: {fileID: 11500000, guid: 5dc8c43a2eed342d1bf5308bf1be7aed, type: 3}
  m_Name: enterprise_contract
  m_EditorClassIdentifier: AICompanyTycoon.Data::AICompanyTycoon.Data.GameEventDef
  id: enterprise_contract
  displayName: Enterprise Contract Offer
  description: A Fortune 500 company wants to use your AI. They need reliability
    guarantees.
  weight: 7
  conditions:
  - key: min_month
    value: 4
  - key: min_trust
    value: 40
  choices:
  - id: accept_contract
    text: "Accept the contract \u2014 deliver on their terms"
    description: +$5000, +5 Trust, -1 Talent (dedicated to client)
    effects:
    - resource: 0
      amount: 5000
    - resource: 4
      amount: -1
    - resource: 5
      amount: 5
  - id: negotiate
    text: Negotiate for better terms and more time
    description: +$3000, +3 Trust (less pressure)
    effects:
    - resource: 0
      amount: 3000
    - resource: 5
      amount: 3
  - id: decline
    text: "Decline \u2014 we're not ready for enterprise yet"
    description: -3 Hype (missed opportunity)
    effects:
    - resource: 6
      amount: -3
